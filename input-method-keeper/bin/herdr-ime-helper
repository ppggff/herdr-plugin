#!/bin/sh
set -eu

ROOT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
SRC="$ROOT_DIR/helpers/herdr-ime-helper.swift"

if [ -n "${HERDR_IME_HELPER_BIN:-}" ]; then
  exec "$HERDR_IME_HELPER_BIN" "$@"
fi

SWIFTC="${HERDR_IME_HELPER_SWIFTC:-}"
if [ -z "$SWIFTC" ]; then
  SWIFTC=$(command -v swiftc || true)
fi
if [ -z "$SWIFTC" ]; then
  printf '%s\n' "herdr-ime-helper: swiftc not found" >&2
  exit 127
fi

if [ -n "${HERDR_PLUGIN_STATE_DIR:-}" ]; then
  BUILD_DIR="$HERDR_PLUGIN_STATE_DIR/helper-build"
else
  BUILD_DIR="${TMPDIR:-/tmp}/herdr-ime-helper-${USER:-user}"
fi
BIN="$BUILD_DIR/herdr-ime-helper"

mkdir -p "$BUILD_DIR"

if [ ! -x "$BIN" ] || [ "$SRC" -nt "$BIN" ]; then
  LOCK_DIR="$BUILD_DIR/.compile.lock"
  LOCK_START=$(date +%s)
  lock_mtime() {
    stat -f %m "$LOCK_DIR" 2>/dev/null || stat -c %Y "$LOCK_DIR" 2>/dev/null || printf '0\n'
  }
  while ! mkdir "$LOCK_DIR" 2>/dev/null; do
    NOW=$(date +%s)
    LOCK_PID=$(cat "$LOCK_DIR/pid" 2>/dev/null || true)
    LOCK_CREATED=$(cat "$LOCK_DIR/created_at" 2>/dev/null || true)
    case "$LOCK_CREATED" in
      ''|*[!0-9]*) LOCK_CREATED=$(lock_mtime) ;;
    esac
    if [ -n "$LOCK_PID" ] && ! kill -0 "$LOCK_PID" 2>/dev/null; then
      rm -rf "$LOCK_DIR"
      continue
    fi
    if [ -z "$LOCK_PID" ] && [ "$LOCK_CREATED" -gt 0 ] && [ $((NOW - LOCK_CREATED)) -gt 30 ]; then
      rm -rf "$LOCK_DIR"
      continue
    fi
    if [ $((NOW - LOCK_START)) -gt 30 ]; then
      printf '%s\n' "herdr-ime-helper: timed out waiting for compile lock: $LOCK_DIR" >&2
      exit 1
    fi
    sleep 0.05
  done
  printf '%s\n' "$$" > "$LOCK_DIR/pid"
  printf '%s\n' "$(date +%s)" > "$LOCK_DIR/created_at"
  TMP_BIN=""
  cleanup() {
    if [ -n "$TMP_BIN" ]; then
      rm -f "$TMP_BIN"
    fi
    rm -f "$LOCK_DIR/pid" "$LOCK_DIR/created_at"
    rmdir "$LOCK_DIR" 2>/dev/null || true
  }
  trap cleanup EXIT HUP INT TERM
  MODULE_CACHE="$BUILD_DIR/module-cache"
  mkdir -p "$MODULE_CACHE"
  if [ ! -x "$BIN" ] || [ "$SRC" -nt "$BIN" ]; then
    TMP_BIN="$BUILD_DIR/.herdr-ime-helper.$$"
    CLANG_MODULE_CACHE_PATH="$MODULE_CACHE" "$SWIFTC" "$SRC" -o "$TMP_BIN"
    mv "$TMP_BIN" "$BIN"
    TMP_BIN=""
  fi
  cleanup
  trap - EXIT HUP INT TERM
fi

exec "$BIN" "$@"
